{
  "name": "@gks101/port-kill",
  "version": "1.0.2",
  "description": "Highly maintainable, lightweight, cross-platform programmatic API and zero-dependency CLI tool to terminate processes running on specific ports.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "port-kill": "dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "port-kill",
    "kill-port",
    "port-kill-cli",
    "process-kill",
    "term-port",
    "netstat",
    "lsof",
    "cross-platform",
    "ci-cd",
    "test-cleanup"
  ],
  "author": "Gaurav Singh <gaurav.kr.singh1@gmail.com>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0"
  }
}
